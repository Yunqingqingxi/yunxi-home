# =============================================================================
# Yunxi Home - 环境变量配置模板
# 复制为 .env 并填入实际值
# =============================================================================

# 域名 (用于 WireGuard、RustDesk、证书等)
DOMAIN=example.com

# 时区
TZ=Asia/Shanghai

# 存储路径
NAS_STORAGE_PATH=/mnt/nas
MEDIA_PATH=/mnt/media
DOWNLOAD_PATH=/mnt/downloads
PHOTO_PATH=/mnt/photos

# =============================================================================
# 服务密码
# =============================================================================
# Nextcloud
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme
NEXTCLOUD_DB_PASSWORD=changeme
NEXTCLOUD_DB_ROOT_PASSWORD=changeme

# Immich
IMMICH_DB_PASSWORD=changeme

# WireGuard
WG_PASSWORD=changeme

# Aria2
ARIA2_RPC_SECRET=changeme

# Yunxi Home
YUNXI_ADMIN_PASSWORD=changeme
YUNXI_JWT_SECRET=changeme
YUNXI_ENCRYPTION_KEY=changeme

# Open WebUI
WEBUI_SECRET_KEY=changeme

# =============================================================================
# 阿里云 DNS (用于 DDNS)
# =============================================================================
ALIDNS_KEY_ID=your-access-key-id
ALIDNS_KEY_SECRET=your-access-key-secret
